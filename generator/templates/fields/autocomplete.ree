<field-wrapper class="grid relative" data-field="__field.name__">
	<label class="px-3" for="__field.name___search">{_ labels.__field.name__ }</label>
	<auto-complete
	field-name="__field.name__"
	fk-table="__fk.table__"
	fk-column="__fk.column__"
	base-url="__route_prefix__/__table.exact__"
	rows="__autocomplete.rows__"
></auto-complete>
<validation-error class="mt-1" id="error-__field.name__"></validation-error>
</field-wrapper>
