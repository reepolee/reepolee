# ===========================================================================
# Reepolee environment. Copied to .env on install (scripts/copy_env.ts).
# Ordered by how often a developer touches each setting: core first,
# optional features next, test-only and external integrations last.
# ===========================================================================

# -- Core: database & server -- (required to boot)
CONNECTION_STRING=sqlite:app.db
# CONNECTION_STRING="mysql://login:pass@localhost/reepolee_dev"
# Test DB - used by `bun test` and `bun run db:clone-test`. Must contain "test"
# in the DB name; the safety guard refuses non-test DBs. Fails LOUD if unset.
TEST_CONNECTION_STRING=sqlite:test.db
TIME_ZONE=Europe/London
PORT=2338
# Overrides PORT under the --test flag (binds to 127.0.0.1 only). Falls back to
# PORT then 2338. The smoke test script defaults to 2600.
# TEST_PORT=2600
SERVER_NAME=localhost
SITE_URL=http://localhost:2338

# Optional: complete Ree-web Publisher signal endpoint. Successful CRUD
# mutations notify it on a best-effort basis and never depend on its response.
# REEWEB_PUBLISHER_URL=http://localhost:3011/api/render-signal

# -- Sessions --
# "sql" (default, no extra services) or "redis" (requires REDIS_URL below).
SESSION_STORE="sql"

# -- Storage --
# "local" keeps uploads on disk; "s3" uses the S3 block further down.
STORAGE="local"
LOCAL_STORAGE_DIR="../storage"

# -- Email (SMTP) --
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USERNAME="xxxxxxxxxxxxxx"
SMTP_PASSWORD="yyyyyyyyyyyyyy"
SMTP_FROM="example@example.com"

# -- Common app toggles --
SQL_LOGGING=false
TRANSLATED_ROUTES=true
MAX_UPLOAD_SIZE_MB=10

# -- MCP server --
# Local stdio only; never expose an MCP bridge on a network port.
# Template rendering and all mutation tools are disabled by default.
# MCP_ENABLE_TEMPLATE_RENDER=true
# MCP_ENABLE_MUTATIONS=true
# MySQL only: use a separate SELECT-only database user for inspection.
# MCP_READONLY_CONNECTION_STRING="mysql://mcp_reader:password@localhost/reepolee_dev"

# -- Internal admin endpoints --
# Disabled by default. Set both values in the deployment environment only when
# translation reload and rate-limit endpoints are required. Generate a 32+ byte
# secret with: openssl rand -hex 32
# INTERNAL_ADMIN_ENDPOINTS=true
# RELOAD_SECRET=

# ===========================================================================
# Redis (optional) - sessions, SQL cache, background queue.
# Uncomment REDIS_URL to enable; leave it unset for a Redis-free install.
# Rate limiting (further down) uses Redis when REDIS_URL is set but falls back
# to the SQL database, so it does not require Redis.
# ===========================================================================

# REDIS_URL="redis://localhost:6379"
# Real Redis for Redis-backed tests (e.g. cache.test.ts). Use a different DB
# number (e.g. /1) to isolate from the dev server. Those tests skip when unset.
# TEST_REDIS_URL=redis://localhost:6379/1

# -- Redis SQL cache --
# Set to "true" to enable Redis-backed caching of search_records queries.
# Requires REDIS_URL. Falls back silently when disabled.
CACHE_ENABLED=false
# Max serialized bytes for a cached value (default: 524288 = 512 KB)
# CACHE_MAX_BYTES=524288
# Max record count for cached query results (default: 500)
# CACHE_MAX_RECORDS=500

# -- Rate limiting --
# Required in production. Set both values in the deployment environment.
# Local development may leave them unset.
# RATE_LIMITING=true
#
# TRUST_PROXY tells the limiter how to find the real client IP for anonymous
# traffic. Production requires one of the two modes below; anything else exits.
# Logged-in users are keyed by session cookie and are unaffected either way.
#
#   cloudflare - Cloudflare is the ONLY path to the origin; CF-Connecting-IP is
#                trusted. Allow only Cloudflare IP ranges at the origin firewall
#                so the header cannot be spoofed.
#   direct     - No proxy in front. The socket peer address is used, which the
#                client cannot spoof. Correct for LAN / direct-to-origin only:
#                behind a proxy every request reports the proxy's address and
#                all anonymous traffic collapses into one bucket.
#
# TRUST_PROXY=cloudflare
# TRUST_PROXY=direct
#
# RATE_LIMITING=true does NOT require Redis. The counter store is picked from
# config: Redis when REDIS_URL is set, otherwise the SQL database via the
# rate_limit_counters table. Expired counters are swept every 5 minutes on the
# SQL path; Redis expires its own keys.

# ===========================================================================
# S3 object storage (only when STORAGE="s3")
# ===========================================================================

# Connection - split style (preferred). Endpoint is built as
# S3_PROTOCOL://S3_HOSTNAME:S3_PORT.
S3_HOSTNAME="localhost"
S3_PORT=8333
S3_PROTOCOL="http"

# Credentials
S3_ACCESS_KEY_ID="user"
S3_SECRET_ACCESS_KEY="user1234"

# Region (optional)
S3_REGION="auto"

# Image bucket - used for uploaded images via the image editor. Default: "images"
S3_IMAGE_BUCKET="images"

# -- Local storage path override (when S3 is not configured) --
# If set, avatars and uploaded images are stored outside the application
# directory so they survive reinstalls. Sub-directories mirror S3 mount buckets
# (avatars/ and images/). If unset, avatars fall back to static/avatars/.
# LOCAL_STORAGE_DIR="/opt/reepolee-data"

# ===========================================================================
# AI / translation providers (optional) - pick one; see generator/ai-provider.ts
# for precedence (Ollama > Gemini > HF when OPENROUTER_KEY is unset > OpenRouter).
# ===========================================================================

# -- OpenRouter --
OPENROUTER_KEY=https://openrouter.ai/workspaces/default/keys
OPENROUTER_MODEL=poolside/laguna-xs-2.1:free

# -- Gemini --
# GEMINI_API_KEY=xxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-2.5-flash

# -- Local LLM (Ollama) -- takes priority over all other providers when set.
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="gemma4:e4b"

# -- HF Inference API -- used when HF_TOKEN is set and OPENROUTER_KEY is not.
# Language code (e.g. "en-sl") is derived automatically; defaults to Helsinki-NLP/opus-mt.
# HF_URL="https://router.huggingface.co/hf-inference/models"
# HF_MODEL="Helsinki-NLP/opus-mt"
# HF_TOKEN="hf_*****"

# ===========================================================================
# Agent mode (optional, testing)
# ===========================================================================

# Required by `bun run agent` - the server exits without it (never falls back to 2338)
# AGENT_SERVER_PORT=2500
# AGENT_USER_USERNAME=admin
