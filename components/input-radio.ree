<field-wrapper class="grid">
	<fieldset class="px-3">
		<legend>{= props.label}</legend>
		{#each props.options[props.name] as option}
			<label class="flex items-center gap-2">
				<input type="radio" name="{= props.name }" value="{= option.value }" {#if props.value===option.value} checked{/if} />
				{= option.label}
			</label>
		{/each}
	</fieldset>
	<validation-error class="mt-1" id="error-{= props.name }"></validation-error>
</field-wrapper>
