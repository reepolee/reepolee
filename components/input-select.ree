{{ const { name, label, value, options } = props.attributes ?? {}; }}
<field-wrapper class="grid">
	<label class="px-3" for="{= name }">{= label}</label>
	<select id="{= name }" name="{= name }">
		<option value="">-- Select --</option>
		{#each options ?? props.options?.[name] as option}
			<option value="{= option }" {#if option === value} selected{/if}>{= option}</option>
		{/each}
	</select>
	<validation-error class="mt-1" id="error-{= name }"></validation-error>
</field-wrapper>
