{{ const { name, label, value } = props.attributes ?? {}; }}
<field-wrapper class="grid">
	<label class="px-3" for="{= name }">{= label}</label>
	<input type="time" id="{= name }" name="{= name }" value="{= value }" />
	<validation-error class="mt-1" id="error-{= name }"></validation-error>
</field-wrapper>
