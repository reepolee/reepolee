<field-wrapper class="grid">
	<label class="px-3 flex items-center gap-2" for="{= props.name }">
		<input type="checkbox" id="{= props.name }" name="{= props.name }" {#if props.value} checked{/if} />
		{= props.label}
	</label>
	<validation-error class="mt-1" id="error-{= props.name }"></validation-error>
</field-wrapper>
