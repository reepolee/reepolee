<!DOCTYPE html>
<html lang="{= props.lang }" class="{= props.theme_class }">

	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<link rel="stylesheet" href='/app{~ props.is_dev ? "-dev" :"" }.css?v={= props.version }' />
		<title>{= props.translations?.ui?.title || props.site_name}</title>

		<script src="/helpers-client.js?v={= props.version }"></script>
		<script src="/web-components/validation-error.js?v={= props.version }"></script>
		<script src="/web-components/toasts-area.js?v={= props.version }"></script>
		<!-- <script src="/dpu.min.js?v={= props.version }" defer></script> -->

		{#if (!props.is_dev)}
			<!-- {#include('speculationrules.partial')} -->
		{/if}
		<meta http-equiv="Content-Language" content="{= props.lang }" />
	</head>

	<body class="bg-surface grid grid-cols-[30ch_1fr] min-h-screen">

		{#if props.path_lang && props.lang_preferred && props.path_lang !== props.lang_preferred}
			<!-- LANG MISMATCH DIALOG START -->
			<dialog id="lang_mismatch_dialog" class="p-0 rounded-xl shadow-2xl min-w-100">
				<div class="p-6">
					<h2 class="text-lg font-semibold">{_ ui.lang_mismatch_title}</h2>
					<p class="text-slate-600 mt-2">
						{_ ui.lang_mismatch_body}
						<strong>{= props.path_lang_name}</strong>
					</p>
					<div class="mt-6 flex justify-end gap-2">
						<form method="dialog">
							<button class="px-3 py-1 rounded bg-slate-200" value="dismiss">{_ actions.lang_mismatch_dismiss}</button>
						</form>
						<a href="?lang={= props.lang_preferred }" class="px-3 py-1 rounded bg-brand text-white no-underline">{_ actions.lang_mismatch_switch}</a>
					</div>
				</div>
			</dialog>
			<script>
				document.getElementById("lang_mismatch_dialog")?.showModal();
			</script>
			<!-- LANG MISMATCH DIALOG END -->
		{/if}

		<nav class="flex py-4 bg-neutral-200 gap-4 pb-8 flex-col border-r border-r-neutral-300 justify-between h-screen sticky top-0 overflow-y-auto" style="scrollbar-gutter: stable">

			<div class="top flex flex-col">
				<a href="/" class="px-4 mb-4">
					<img src="{= props.dark_mode ? '/logo-light.svg' : '/logo-dark.svg' }" alt="Reepolee logo" />
				</a>

				<!-- NAVIGATION START -->

				{#each props.nav_groups as group}
					{#if !group.label || (props.user && props.user.modules_tags && props.user.modules_tags.split(/[\s,]+/).filter(Boolean).includes(group.label.toLowerCase()))}
						{#if group.label}
							<details class="group mb-8" data-nav-module="{= group.label }" {#if !props.collapsed_nav_modules.includes(group.label) }open{/if}>
								<summary class="flex cursor-pointer items-center px-4 text-xs font-semibold uppercase tracking-wider text-brand marker:content-none">
									<span class="mr-2 transition-transform group-open:rotate-90">❯</span>
									{= props.translations.nav_prefix_title?.[group.label]}
								</summary>
								<div class="mt-2 flex flex-col">
									{#each group.items as entry}
										<a href="{~ localized_path(entry.url) }" class="{= is_current(localized_path(entry.url)) } pl-6 hover:bg-neutral-100">{= nav_label(entry.nav_title_key)}</a>
									{/each}
								</div>
							</details>
						{:else}
							{#each group.items as entry}
								<a href="{~ localized_path(entry.url) }" class="{= is_current(localized_path(entry.url)) } pl-6 hover:bg-neutral-100">{= nav_label(entry.nav_title_key)}</a>
							{/each}
							<div class="mb-8"></div>
						{/if}

					{/if}
				{/each}

				<!-- NAVIGATION END -->

			</div>

			<div class="bottom flex flex-col gap-2 px-4">
				<div class="flex items-center gap-2">
					{#each props.active_languages as lang}
						<a href="?lang={= lang }" class="{= props.lang === lang ? 'font-bold' : '' }">{= lang.toUpperCase()}</a>
					{/each}
					<button id="theme-toggle" aria-label="Toggle dark mode" class="ml-auto cursor-pointer px-2 py-1 text-xs rounded border border-neutral-300 hover:bg-neutral-100">🌙</button>
				</div>
				<div class="flex items-center gap-2 font-semibold" title="{= Bun.env.CONNECTION_STRING}">
					{#if props.user}
						<a href="{~ localized_path('/profile') }">{= props.user.display_name}</a>
					{:else}
						<a href="{~ localized_path('/login') }">{_ nav_auth.login}</a>
					{/if}
				</div>

			</div>

		</nav>

		<main id="main" class="min-w-0">{~ props.body}</main>

		<toasts-area id="toasts-area"></toasts-area>

		<!-- TOASTS	-->
		{#if props.toasts?.length>0}
			<script>
				{#each props.toasts as toast, i}
					add_toast({~ JSON.stringify(toast)});
				{/each}
			</script>
		{/if}
		{#if is_dev}
			<script>
				console.info({~ props.toJSON});
				window.addEventListener("pageshow", (event) => {
					if (event.persisted) {
						console.log("Page restored from BFCache");
					} else {
						console.log("Normal page load");
					}
				});
				const nav = performance.getEntriesByType("navigation")[0];
				console.log("navigation type:", nav?.type);
			</script>
		{/if}
	</body>

	<script>
		init_theme_toggle();

		const nav_module_details = document.querySelectorAll("details[data-nav-module]");
		for (const nav_module_detail of nav_module_details) {
			nav_module_detail.addEventListener("toggle", () => {
				const collapsed_modules = Array.from(document.querySelectorAll("details[data-nav-module]:not([open])"), (element) => element.dataset.navModule);
				const cookie_value = encodeURIComponent(JSON.stringify(collapsed_modules));
				document.cookie = `nav_collapsed_modules=${cookie_value}; path=/; max-age=31536000; samesite=lax`;
			});
		}
	</script>

</html>
