{
	"compilerOptions": {
		"types": [
			"bun"
		],
		"lib": [
			"ESNext"
		],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"allowJs": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false,
		"paths": {
			"$config/*": [
				"./config/*"
			],
			"$lib/*": [
				"./lib/*"
			],
			"$root/*": [
				"./*"
			],
			"$queue/*": [
				"./queue/*"
			],
			"$vendor/*": [
				"./vendor/*"
			],
			"$routes/*": [
				"./routes/*"
			],
			"$generator/*": [
				"./generator/*"
			]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.d.ts",
		"scripts/install/reettier.ts"
	],
	"exclude": [
		"generator/templates/**",
		"generator/simple-route/**"
	]
}
